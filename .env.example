# =============================================================================
# COPY THIS FILE TO `.env` AND FILL IN VALUES.
# Never commit `.env` (it is gitignored).
# =============================================================================

# --- Default: Google Gemini (both analysis + final report) ---
# Free API key: https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=

# --- Optional: OpenAI instead of Gemini ---
# Set LLM_PROVIDER=openai and provide OPENAI_API_KEY.
# OPENAI_API_KEY=

# --- OPTIONAL: NCBI E-utilities (higher PubMed rate limits) ---
# https://www.ncbi.nlm.nih.gov/account/ → API Key Management
NCBI_API_KEY=

# --- OPTIONAL: contact email (recommended for NCBI Entrez policy) ---
CONTACT_EMAIL=your.email@institution.edu

# --- OPTIONAL: model overrides ---
# GEMINI_MODEL=gemini-2.5-flash
# Seconds between Gemini calls (helps stay under free-tier requests/minute):
# GEMINI_DELAY_SEC=6
# OPENAI_MODEL=gpt-4o
