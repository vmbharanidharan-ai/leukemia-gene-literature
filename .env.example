# =============================================================================
# COPY THIS FILE TO `.env` AND FILL IN VALUES.
# Never commit `.env` (it is gitignored).
# =============================================================================

# --- REQUIRED: Claude (literature analysis) ---
# Get a key: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=

# --- REQUIRED: OpenAI (structure / synthesize final report) ---
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- OPTIONAL: NCBI E-utilities (higher PubMed rate limits) ---
# Without a key: max ~3 requests/sec per IP. With key: up to ~10 req/sec.
# Create an NCBI account → Account settings → API Key Management
# https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# --- OPTIONAL: contact email (recommended for NCBI Entrez policy) ---
CONTACT_EMAIL=your.email@institution.edu

# --- OPTIONAL: model overrides ---
# CLAUDE_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o
