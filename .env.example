# =============================================================================
# COPY THIS FILE TO `.env` AND FILL IN VALUES.
# Never commit `.env` (it is gitignored).
# =============================================================================

# --- Choose LLM backend: openai | gemini ---
# openai: needs OPENAI_API_KEY (paid; may include trial credits for new accounts)
# gemini: needs GEMINI_API_KEY only — free tier keys from Google AI Studio:
#         https://aistudio.google.com/apikey
#         Then run: pip install -e ".[gemini]"
LLM_PROVIDER=openai

# --- OpenAI (when LLM_PROVIDER=openai) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Google Gemini (when LLM_PROVIDER=gemini) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- OPTIONAL: NCBI E-utilities (higher PubMed rate limits) ---
# https://www.ncbi.nlm.nih.gov/account/ → API Key Management
NCBI_API_KEY=

# --- OPTIONAL: contact email (recommended for NCBI Entrez policy) ---
CONTACT_EMAIL=your.email@institution.edu

# --- OPTIONAL: model overrides ---
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-1.5-flash
